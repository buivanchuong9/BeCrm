  version              Int             @default(1)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clinicLocation   ClinicLocation?           @relation(fields: [clinicLocationId], references: [id], onDelete: SetNull)
  patient          Patient                   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointment      Appointment?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  parentEncounter  MedicalEncounter?         @relation("EncounterFollowUp", fields: [parentEncounterId], references: [id], onDelete: SetNull)
  childEncounters  MedicalEncounter[]        @relation("EncounterFollowUp")
