  status         String    @default("draft")
  diagnosisId    String?   @map("diagnosis_id") @db.Uuid
  prescriptionId String?   @map("prescription_id") @db.Uuid
  discharge      Json?
  followUp       Json?     @map("follow_up")
  signedBy       String?   @map("signed_by") @db.Uuid
  signedAt       DateTime? @map("signed_at") @db.Timestamptz
  reopenedReason String?   @map("reopened_reason")
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status])
  @@map("medical_records")
}

model MedicalRecordAddendum {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId String   @map("record_id") @db.Uuid
  text     String
  addedBy  String   @map("added_by") @db.Uuid
  addedAt  DateTime @default(now()) @map("added_at") @db.Timestamptz

  @@index([recordId, addedAt])
  @@map("medical_record_addenda")
}

model Prescription {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId String   @map("encounter_id") @db.Uuid
  doctorId    String   @map("doctor_id") @db.Uuid
  medications Json
  issuedAt    DateTime @default(now()) @map("issued_at") @db.Timestamptz

  @@index([encounterId, issuedAt])
  @@map("prescriptions")
}

model ClinicalDocument {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId       String   @map("encounter_id") @db.Uuid
  workflowTaskId    String?  @map("workflow_task_id") @db.Uuid
  clinicalOrderId   String?  @map("clinical_order_id") @db.Uuid
  type              String
  fileId            String   @map("file_id") @db.Uuid
  fileName          String   @map("file_name")
  fileHash          String   @map("file_hash")
