// ---------------------------------------------------------------------------
// Workflow / BPM (T12 — docs section 27-28). WorkflowStepDefinition[] is
// stored as JSON on the version row rather than a child table: it is edited
// wholesale as a coherent graph (cycle detection spans the whole array) and
// copy-on-instantiate snapshots it verbatim into WorkflowTask rows at
// activation time — there is no independent query/filter need that would
// justify a relational child table. Step CRUD is exposed as one bulk
// PUT .../steps replace-the-array endpoint rather than the granular
// add/edit/remove/reorder/connect/disconnect endpoint-per-operation split a
// fuller spec might use — same safety guarantees (self-reference rejection,
// cycle detection, mandatory-step protection), much less surface area.
// ---------------------------------------------------------------------------

enum WorkflowTemplateStatus {
  draft
  in_review
  published
  deprecated
  archived
}

model WorkflowTemplate {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId           String   @map("organization_id") @db.Uuid
  name                     String
  specialty                String
  description              String
  createdBy                String   @map("created_by") @db.Uuid
  latestPublishedVersionId String?  @map("latest_published_version_id") @db.Uuid
  version                  Int      @default(1)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  versions WorkflowTemplateVersion[]

  @@index([organizationId, specialty])
  @@map("workflow_templates")
}

model WorkflowTemplateVersion {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId    String                 @map("template_id") @db.Uuid
  versionNumber Int                    @map("version_number")
  status        WorkflowTemplateStatus @default(draft)
  // WorkflowStepDefinition[] — {code,icon?,executorType?,name,description,
  // taskType,responsibleRole,department,skill?,location?,mandatory,
  // conditionalRule?,estimatedDurationMinutes,maxWaitingMinutes,
  // skipPermission[],reworkRule?,escalationRule?,notificationRule?,
  // requiredOutput?,prerequisiteStepCodes[]}
  steps         Json                   @default("[]")
  nodePositions Json?                  @map("node_positions")
  // Optimistic lock for concurrent draft edits — distinct from
  // `versionNumber` (the human-facing template version, e.g. v1/v2/v3).
  rowVersion    Int                    @default(1) @map("row_version")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz
  publishedAt   DateTime?              @map("published_at") @db.Timestamptz

  template  WorkflowTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)
  instances WorkflowInstance[]

  @@unique([templateId, versionNumber])
  @@index([templateId])
  @@map("workflow_template_versions")
}

enum WorkflowInstanceStatus {
  created
  active
  suspended
  completed
  cancelled
}

model WorkflowInstance {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId         String                 @map("patient_id") @db.Uuid
  encounterId       String                 @unique @map("encounter_id") @db.Uuid
  templateId        String                 @map("template_id") @db.Uuid
  templateVersionId String                 @map("template_version_id") @db.Uuid
  instanceCode      String                 @unique @map("instance_code")
  // Server-side HMAC-SHA256 over patientId|encounterId|templateVersionId|id,
  // keyed with a server-only secret — replaces the frontend prototype's
  // client-side FNV-1a placeholder (docs section 28 ACT-1, section 45).
  integrityHash     String                 @map("integrity_hash")
  identityVersion   Int                    @default(1) @map("identity_version")
  status            WorkflowInstanceStatus @default(active)
  activatedBy       String                 @map("activated_by") @db.Uuid
  activatedAt       DateTime               @default(now()) @map("activated_at") @db.Timestamptz
  completedAt       DateTime?              @map("completed_at") @db.Timestamptz
  suspendedReason   String?                @map("suspended_reason")
  version           Int                    @default(1)

  encounter       MedicalEncounter        @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  templateVersion WorkflowTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  tasks           WorkflowTask[]

  @@index([patientId])
  @@map("workflow_instances")
}

enum WorkflowTaskStatus {
  pending
  blocked
  ready
  assigned
  accepted
  in_progress
  waiting_for_patient
  waiting_for_result
  waiting_for_approval
  completed
  failed
  rejected
  redo_required
  skipped
  cancelled
  expired
  escalated
}

enum WorkflowPriority {
  low
  medium
  high
}

model WorkflowTask {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId         String             @map("instance_id") @db.Uuid
  encounterId        String             @map("encounter_id") @db.Uuid
  stepCode           String             @map("step_code")
  name               String
  responsibleRole    UserRole           @map("responsible_role")
  department         String
  status             WorkflowTaskStatus @default(pending)
  assigneeId         String?            @map("assignee_id") @db.Uuid
  dependsOnStepCodes String[]           @map("depends_on_step_codes")
  slaMinutes         Int                @map("sla_minutes")
  priority           WorkflowPriority   @default(medium)
  urgency            Urgency            @default(routine)
  mandatory          Boolean            @default(false)
  clinicalWarning    String?            @map("clinical_warning")
  reworkCount        Int                @default(0) @map("rework_count")
  version            Int                @default(1)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  startedAt          DateTime?          @map("started_at") @db.Timestamptz
  completedAt        DateTime?          @map("completed_at") @db.Timestamptz

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Restrict)

  @@index([instanceId])
  @@index([encounterId])
  @@index([responsibleRole, department, status])
  @@index([assigneeId, status])
  @@map("workflow_tasks")
}

// ---------------------------------------------------------------------------
// EMR, CRM, notifications and operational API backing stores.
// Closed state transitions are enforced in their services; JSON is used only
// for cohesive value objects (medications, discharge instructions, metadata).
// ---------------------------------------------------------------------------

model MedicalRecord {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
