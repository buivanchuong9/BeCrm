  orderedByDoctorId   String              @map("ordered_by_doctor_id") @db.Uuid
  justification       String
  status              ClinicalOrderStatus @default(requested)
  assignedRole        UserRole            @map("assigned_role")
  invalidSampleReason String?             @map("invalid_sample_reason")
  version             Int                 @default(1)
