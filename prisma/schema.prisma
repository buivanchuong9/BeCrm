// DermaHealth backend — Prisma schema (T01/T02/T03 foundation).
// GiST exclusion constraints, citext, partial indexes and the append-only
// audit trigger are added via handwritten SQL in prisma/migrations — Prisma's
// declarative schema cannot express them.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ---------------------------------------------------------------------------
// Identity / organization scope (T03)
// ---------------------------------------------------------------------------

enum UserRole {
  super_administrator
  patient
  doctor
  nurse
  receptionist
  lab_technician
  imaging_technician
  pharmacist
  care_coordinator
  customer_care_employee
  medical_administrator
  system_administrator
  clinical_process_designer
}

enum UserStatus {
  pending_activation
  active
  suspended
  deactivated
}

enum MembershipStatus {
  active
  revoked
}

enum ClinicLocationStatus {
  active
  inactive
}

model Organization {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String               @unique
  name        String
  timezone    String               @default("Asia/Ho_Chi_Minh")
  addressJson Json?                @map("address_json")
  status      ClinicLocationStatus @default(active)
  version     Int                  @default(1)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  clinicLocations               ClinicLocation[]
  departments                   Department[]
  memberships                   UserMembership[]
  patients                      Patient[]
  appointments                  Appointment[]
  encounters                    MedicalEncounter[]
  queueTickets                  QueueTicket[]
  kioskDevices                  KioskDevice[]
  specialties                   Specialty[]
  practitionerClinicAssignments PractitionerClinicAssignment[]

  @@map("organizations")
}

model ClinicLocation {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  code           String
  name           String
  timezone       String               @default("Asia/Ho_Chi_Minh")
  addressJson    Json?                @map("address_json")
  status         ClinicLocationStatus @default(active)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  organization                  Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  departments                   Department[]
  memberships                   UserMembership[]
  appointments                  Appointment[]
  encounters                    MedicalEncounter[]
  queueTickets                  QueueTicket[]
  kioskDevices                  KioskDevice[]
  practitionerClinicAssignments PractitionerClinicAssignment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("clinic_locations")
}

model Department {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String               @map("organization_id") @db.Uuid
  clinicLocationId String?              @map("clinic_location_id") @db.Uuid
  code             String
  name             String
  status           ClinicLocationStatus @default(active)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  organization                  Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clinicLocation                ClinicLocation?                @relation(fields: [clinicLocationId], references: [id], onDelete: Restrict)
  memberships                   UserMembership[]
  practitionerClinicAssignments PractitionerClinicAssignment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String     @unique @db.Citext
  passwordHash     String?    @map("password_hash")
  displayName      String     @map("display_name")
  phone            String?
  avatarFileId     String?    @map("avatar_file_id") @db.Uuid
  status           UserStatus @default(pending_activation)
  mfaEnabled       Boolean    @default(false) @map("mfa_enabled")
  mfaSecretEnc     String?    @map("mfa_secret_enc")
  emailVerifiedAt  DateTime?  @map("email_verified_at") @db.Timestamptz
  failedLoginCount Int        @default(0) @map("failed_login_count")
  lockedUntil      DateTime?  @map("locked_until") @db.Timestamptz
  version          Int        @default(1)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  memberships             UserMembership[]
  refreshSessions         RefreshSession[]
  preference              UserPreference?
  patientProfile          Patient?                @relation("PatientOwner")
  primaryDoctorOf         Patient[]               @relation("PatientPrimaryDoctor")
  careTeamOf              PatientCareTeamMember[]
  doctorAppointments      Appointment[]           @relation("AppointmentDoctor")
  currentDoctorEncounters MedicalEncounter[]      @relation("EncounterCurrentDoctor")
  practitionerProfile     PractitionerProfile?

  @@map("users")
}

model UserPreference {
  userId               String   @id @map("user_id") @db.Uuid
  locale               String   @default("vi-VN")
  timezone             String   @default("Asia/Ho_Chi_Minh")
  dateFormat           String   @default("DD/MM/YYYY") @map("date_format")
  theme                String   @default("system")
  notificationChannels Json     @default("{\"inApp\":true,\"email\":true,\"sms\":false,\"push\":false}") @map("notification_channels")
  deviceSettings       Json     @default("{\"biometricLogin\":false,\"mobileNotifications\":true}") @map("device_settings")
  version              Int      @default(1)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserMembership {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  clinicLocationId String?          @map("clinic_location_id") @db.Uuid
  departmentId     String?          @map("department_id") @db.Uuid
  role             UserRole
  status           MembershipStatus @default(active)
  startsAt         DateTime         @default(now()) @map("starts_at") @db.Timestamptz
  endsAt           DateTime?        @map("ends_at") @db.Timestamptz
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clinicLocation ClinicLocation? @relation(fields: [clinicLocationId], references: [id], onDelete: Restrict)
  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Uniqueness is enforced by two handwritten partial unique indexes (migration
  // 20260714094500_membership_partial_unique_indexes), not a Prisma @@unique:
  // Postgres treats NULL as distinct per row in a plain unique index, so a
  // single (user, org, clinic, role) constraint cannot dedupe org-wide
  // memberships (clinicLocationId = NULL) — see decision D-006/F-004.
  @@index([organizationId, role])
  @@index([userId])
  @@map("user_memberships")
}

model RefreshSession {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  familyId      String    @map("family_id") @db.Uuid
  tokenHash     String    @unique @map("token_hash")
  deviceLabel   String?   @map("device_label")
  ip            String?
  userAgent     String?   @map("user_agent")
  issuedAt      DateTime  @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz
  revokedReason String?   @map("revoked_reason")
  replacedById  String?   @map("replaced_by_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_sessions")
}

// ---------------------------------------------------------------------------
// Platform foundation (T02): audit, transactional outbox, idempotency
// ---------------------------------------------------------------------------

enum IdempotencyStatus {
  in_progress
  completed
  failed
}

model IdempotencyRecord {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Nullable principal (anonymous kiosk/public callers) is stored as the fixed
  // NIL UUID sentinel, never SQL NULL — Postgres treats NULL as distinct per row
  // in unique constraints, which would silently defeat idempotency dedup.
  principalId        String            @map("principal_id") @db.Uuid
  principalScope     String            @map("principal_scope")
  route              String
  target             String            @default("")
  idempotencyKey     String            @map("idempotency_key")
  requestFingerprint String            @map("request_fingerprint")
  status             IdempotencyStatus @default(in_progress)
  responseStatus     Int?              @map("response_status")
  responseBody       Json?             @map("response_body")
  expiresAt          DateTime          @map("expires_at") @db.Timestamptz
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([principalScope, principalId, route, target, idempotencyKey], name: "uniq_idempotency_scope")
  @@index([expiresAt])
  @@map("idempotency_records")
}

enum OutboxStatus {
  pending
  dispatched
  failed
}

model OutboxEvent {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateType String       @map("aggregate_type")
  aggregateId   String       @map("aggregate_id") @db.Uuid
  eventType     String       @map("event_type")
  payload       Json
  deliveryKey   String       @map("delivery_key")
  status        OutboxStatus @default(pending)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now()) @map("available_at") @db.Timestamptz
  lastError     String?      @map("last_error")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  dispatchedAt  DateTime?    @map("dispatched_at") @db.Timestamptz

  @@unique([deliveryKey])
  @@index([status, availableAt])
  @@map("outbox_events")
}

model AuditEvent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  occurredAt       DateTime @default(now()) @map("occurred_at") @db.Timestamptz
  actorId          String?  @map("actor_id") @db.Uuid
  actorRoleSnap    String?  @map("actor_role_snapshot")
  actorNameSnap    String?  @map("actor_name_snapshot")
  action           String
  resourceType     String   @map("resource_type")
  resourceId       String?  @map("resource_id") @db.Uuid
  patientId        String?  @map("patient_id") @db.Uuid
  organizationId   String?  @map("organization_id") @db.Uuid
  clinicLocationId String?  @map("clinic_location_id") @db.Uuid
  requestId        String?  @map("request_id") @db.Uuid
  ip               String?
  userAgent        String?  @map("user_agent")
  result           String
  reason           String?
  changedFields    Json?    @map("changed_fields")
  beforeRedacted   Json?    @map("before_redacted")
  afterRedacted    Json?    @map("after_redacted")
  breakGlass       Boolean  @default(false) @map("break_glass")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([organizationId, occurredAt])
  @@index([patientId, occurredAt])
  @@index([actorId, occurredAt])
  @@index([resourceType, resourceId])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// Patients, care team, and consent (T04)
// ---------------------------------------------------------------------------

enum PatientGender {
  male
  female
  other
  unknown
}

model Patient {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  code            String
  userId          String?       @unique @map("user_id") @db.Uuid
  name            String
  dob             DateTime      @db.Date
  gender          PatientGender @default(unknown)
  phone           String
  email           String?
  address         String?
  // Checked text, not a Prisma enum, so the raw '+'/'-' values ('A+','O-',...)
  // from docs/api.md's BloodType union are stored/returned verbatim with no
  // enum-identifier translation layer. Constrained by a CHECK in the SQL
  // migration, not just application validation.
  bloodType       String        @default("unknown") @map("blood_type")
  primaryDoctorId String?       @map("primary_doctor_id") @db.Uuid
  version         Int           @default(1)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user          User?                   @relation("PatientOwner", fields: [userId], references: [id], onDelete: SetNull)
  primaryDoctor User?                   @relation("PatientPrimaryDoctor", fields: [primaryDoctorId], references: [id], onDelete: SetNull)
  consents      Consent[]
  careTeam      PatientCareTeamMember[]
  appointments  Appointment[]
  encounters    MedicalEncounter[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([primaryDoctorId])
  @@map("patients")
}

model PatientCareTeamMember {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String    @map("patient_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  // 'primary_doctor' | 'assigned_doctor' | 'assigned_nurse' | ... — open text
  // rather than an enum since the confirmed relationship vocabulary will grow
  // as T06 (appointments) and T08 (encounters) start populating this table.
  relationship String
  startsAt     DateTime  @default(now()) @map("starts_at") @db.Timestamptz
  endsAt       DateTime? @map("ends_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([userId])
  @@map("patient_care_team")
}

// "current" projection: exactly one row per (patient, type). Historical
// grant/withdraw events live in ConsentEvent (append-only, see migration
// 20260714144627_patients_care_team_consents for the immutability trigger).
model Consent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  type          String
  policyVersion String    @map("policy_version")
  granted       Boolean
  grantedAt     DateTime? @map("granted_at") @db.Timestamptz
  withdrawnAt   DateTime? @map("withdrawn_at") @db.Timestamptz
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  patient Patient        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  events  ConsentEvent[]

  @@unique([patientId, type])
  @@index([patientId])
  @@map("consents")
}

model ConsentEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consentId     String   @map("consent_id") @db.Uuid
  patientId     String   @map("patient_id") @db.Uuid
  type          String
  action        String
  policyVersion String   @map("policy_version")
  actorId       String?  @map("actor_id") @db.Uuid
  reason        String?
  occurredAt    DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  consent Consent @relation(fields: [consentId], references: [id], onDelete: Restrict)

  @@index([patientId, occurredAt])
  @@map("consent_events")
}

// ---------------------------------------------------------------------------
// Practitioner directory and server-authoritative scheduling (T05)
// ---------------------------------------------------------------------------

enum PractitionerStatus {
  active
  inactive
}

enum ScheduleExceptionKind {
  unavailable
  override
}

model PractitionerProfile {
  // A practitioner is the existing User identity. This one-to-one extension
  // deliberately has no independent practitioner identifier.
  userId        String             @id @map("user_id") @db.Uuid
  licenseNumber String             @unique @map("license_number")
  title         String?
  bio           String?
  status        PractitionerStatus @default(active)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user              User                           @relation(fields: [userId], references: [id], onDelete: Restrict)
  specialties       PractitionerSpecialty[]
  clinicAssignments PractitionerClinicAssignment[]

  @@map("practitioner_profiles")
}

model Specialty {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String
  name           String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  practitioners PractitionerSpecialty[]

  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@map("specialties")
}

model PractitionerSpecialty {
  practitionerUserId String   @map("practitioner_user_id") @db.Uuid
  specialtyId        String   @map("specialty_id") @db.Uuid
  primary            Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  practitioner PractitionerProfile @relation(fields: [practitionerUserId], references: [userId], onDelete: Cascade)
  specialty    Specialty           @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@id([practitionerUserId, specialtyId])
  @@index([specialtyId])
  @@map("practitioner_specialties")
}

model PractitionerClinicAssignment {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practitionerUserId  String   @map("practitioner_user_id") @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  clinicLocationId    String   @map("clinic_location_id") @db.Uuid
  departmentId        String   @map("department_id") @db.Uuid
  slotDurationMinutes Int      @default(30) @map("slot_duration_minutes")
  capacity            Int      @default(1)
  active              Boolean  @default(true)
  version             Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  practitioner   PractitionerProfile             @relation(fields: [practitionerUserId], references: [userId], onDelete: Restrict)
  organization   Organization                    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clinicLocation ClinicLocation                  @relation(fields: [clinicLocationId], references: [id], onDelete: Restrict)
  department     Department                      @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  schedules      PractitionerSchedule[]
  exceptions     PractitionerScheduleException[]

  @@unique([practitionerUserId, clinicLocationId, departmentId])
  @@index([organizationId, clinicLocationId, active])
  @@map("practitioner_clinic_assignments")
}

model PractitionerSchedule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignmentId  String    @map("assignment_id") @db.Uuid
  dayOfWeek     Int       @map("day_of_week")
  startMinute   Int       @map("start_minute")
  endMinute     Int       @map("end_minute")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  assignment PractitionerClinicAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, dayOfWeek, active])
  @@map("practitioner_schedules")
}

model PractitionerScheduleException {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignmentId String                @map("assignment_id") @db.Uuid
  kind         ScheduleExceptionKind @default(unavailable)
  startsAt     DateTime              @map("starts_at") @db.Timestamptz
  endsAt       DateTime              @map("ends_at") @db.Timestamptz
  reason       String?
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  assignment PractitionerClinicAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, startsAt, endsAt])
  @@map("practitioner_schedule_exceptions")
}

// ---------------------------------------------------------------------------
// Appointments, QR check-in, queue, and encounters (T06/T07/T08 — docs/api.md
// sections 20-23). Double-booking prevention (tstzrange EXCLUDE constraints),
// the "one active token per appointment" and "one live ticket per appointment"
// partial unique indexes are handwritten SQL in prisma/migrations, same as the
// audit-immutability trigger and membership partial unique indexes above —
// Prisma's declarative schema cannot express GiST exclusion constraints.
// ---------------------------------------------------------------------------

enum KioskDeviceStatus {
  active
  inactive
}

// Server-registered kiosk/reception devices — replaces the frontend
// prototype's client-generated deviceId (docs/api.md section 40, SEC-10).
// Only a device row with status=active may redeem a check-in token.
model KioskDevice {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  clinicLocationId String            @map("clinic_location_id") @db.Uuid
  label            String
  // SHA-256 hash of a server-random device credential, same "hash-only,
  // shown-once" pattern as AppointmentCheckInToken.tokenHash — replaces the
  // frontend prototype's client-generated, unauthenticated deviceId
  // (docs/api.md section 40 SEC-10).
  secretHash       String            @unique @map("secret_hash")
  status           KioskDeviceStatus @default(active)
  registeredBy     String            @map("registered_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clinicLocation    ClinicLocation            @relation(fields: [clinicLocationId], references: [id], onDelete: Restrict)
  checkInTokensUsed AppointmentCheckInToken[]

  @@index([clinicLocationId])
  @@map("kiosk_devices")
}

enum AppointmentMode {
  video
  in_person
}

enum AppointmentStatus {
  upcoming
  done
  cancelled
  missed
}

model Appointment {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  clinicLocationId String            @map("clinic_location_id") @db.Uuid
  patientId        String            @map("patient_id") @db.Uuid
  doctorId         String            @map("doctor_id") @db.Uuid
  department       String
  consultationType String?           @map("consultation_type")
  mode             AppointmentMode
  status           AppointmentStatus @default(upcoming)
  startAt          DateTime          @map("start_at") @db.Timestamptz
  endAt            DateTime          @map("end_at") @db.Timestamptz
  cancelReason     String?           @map("cancel_reason")
  version          Int               @default(1)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clinicLocation ClinicLocation            @relation(fields: [clinicLocationId], references: [id], onDelete: Restrict)
  patient        Patient                   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor         User                      @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  // Virtual reverse of MedicalEncounter.appointmentId (the FK lives on the
  // encounter side — see that model's comment).
  encounter      MedicalEncounter?
  checkInTokens  AppointmentCheckInToken[]
  queueTickets   QueueTicket[]
  history        AppointmentHistory[]

  @@index([organizationId, clinicLocationId])
  @@index([doctorId, startAt])
  @@index([patientId, startAt])
  @@map("appointments")
}

enum CheckInTokenStatus {
  active
  used
  expired
  revoked
  replaced
}

// Only tokenHash (sha256 of a server-random 256-bit token) is ever persisted —
// the raw token is returned exactly once, at issuance, and never stored
// (docs/api.md section 21, section 40 SEC-09). Replaces the frontend
// prototype's client-side FNV-1a "signing" scheme.
model AppointmentCheckInToken {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId    String             @map("appointment_id") @db.Uuid
  patientId        String             @map("patient_id") @db.Uuid
  clinicLocationId String             @map("clinic_location_id") @db.Uuid
  tokenHash        String             @unique @map("token_hash")
  status           CheckInTokenStatus @default(active)
  issuedAt         DateTime           @default(now()) @map("issued_at") @db.Timestamptz
  validFrom        DateTime           @map("valid_from") @db.Timestamptz
  expiresAt        DateTime           @map("expires_at") @db.Timestamptz
  usedAt           DateTime?          @map("used_at") @db.Timestamptz
  usedByDeviceId   String?            @map("used_by_device_id") @db.Uuid
  revokedAt        DateTime?          @map("revoked_at") @db.Timestamptz
  revokedReason    String?            @map("revoked_reason")
  version          Int                @default(1)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz

  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  usedByDevice KioskDevice? @relation(fields: [usedByDeviceId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@map("appointment_check_in_tokens")
}

model AppointmentHistory {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId String             @map("appointment_id") @db.Uuid
  actorId       String?            @map("actor_id") @db.Uuid
  action        String
  fromStatus    AppointmentStatus? @map("from_status")
  toStatus      AppointmentStatus  @map("to_status")
  startsAt      DateTime           @map("starts_at") @db.Timestamptz
  endsAt        DateTime           @map("ends_at") @db.Timestamptz
  reason        String?
  occurredAt    DateTime           @default(now()) @map("occurred_at") @db.Timestamptz

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Restrict)

  @@index([appointmentId, occurredAt])
  @@map("appointment_history")
}

