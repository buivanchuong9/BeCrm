// ---------------------------------------------------------------------------
// Symptom intake, AI preliminary assessment, doctor decision, clinical
// order/result (T09/T10/T11 — docs section 24-26). Actor-attribution columns
// (doctorId, orderedByDoctorId, recordedBy) are deliberately plain scalar
// UUIDs with no Prisma relation/FK, same precedent as AuditEvent.actorId —
// they identify who acted, not a structural ownership relationship, so
// FK/back-array bloat on User isn't warranted. Every FK to MedicalEncounter
// (the core clinical-record parent) is a real Prisma relation.
// ---------------------------------------------------------------------------

model SymptomIntake {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId       String   @map("encounter_id") @db.Uuid
  chiefComplaint    String   @map("chief_complaint")
  severity          Int
  durationDays      Int      @map("duration_days")
  symptoms          String[]
  history           String[]
  currentMedication String[] @map("current_medication")
  // Phase 1/2 simplification: plain string references (no FileObject upload
  // pipeline exists yet, docs section 16 PROPOSED) — never rendered as a
  // trusted URL, treated as an opaque label until real uploads ship.
  images            String[]
  submittedAt       DateTime @default(now()) @map("submitted_at") @db.Timestamptz

  encounter  MedicalEncounter         @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  assessment AIPreliminaryAssessment?

  @@index([encounterId])
  @@map("symptom_intakes")
}

enum AIAssessmentStatus {
  completed
  insufficient_data
  failed
}

enum Urgency {
  routine
  urgent
  emergency
}

// AI must never write DoctorDiagnosis/Prescription/MedicalRecord — enforced
// structurally by the absence of any such relation/field on this model and
// by AiAssessmentService never importing those repositories (docs section 4
// principle 5, section 24).
model AIPreliminaryAssessment {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId          String             @map("encounter_id") @db.Uuid
  intakeId             String             @unique @map("intake_id") @db.Uuid
  status               AIAssessmentStatus
  // CandidateCondition[] — {code,name,confidenceBand,confidenceScore,
  // supportingEvidence[],conflictingEvidence[],rationale}; kept as JSON
  // rather than a child table since it is an immutable, append-only
  // computed-at-generation-time snapshot, never queried/filtered on its own.
  candidateConditions  Json               @map("candidate_conditions")
  redFlagTriggered     Boolean            @map("red_flag_triggered")
  redFlagUrgency       Urgency?           @map("red_flag_urgency")
  redFlagReasons       String[]           @map("red_flag_reasons")
  suggestedSpecialty   String?            @map("suggested_specialty")
  suggestedNextActions String[]           @map("suggested_next_actions")
  modelVersion         String             @map("model_version")
  missingDataHints     String[]           @map("missing_data_hints")
  supersededById       String?            @map("superseded_by_id") @db.Uuid
  generatedAt          DateTime           @default(now()) @map("generated_at") @db.Timestamptz

  encounter              MedicalEncounter          @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  intake                 SymptomIntake             @relation(fields: [intakeId], references: [id], onDelete: Restrict)
  supersededByAssessment AIPreliminaryAssessment?  @relation("AssessmentSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes             AIPreliminaryAssessment[] @relation("AssessmentSupersession")
  reviews                DoctorReview[]
  diagnoses              DoctorDiagnosis[]

  @@index([encounterId])
  @@map("ai_preliminary_assessments")
}

enum DoctorReviewAction {
  pending
  accepted
  partial
  rejected
}

// Sole writer boundary: only doctorDecisionService may create these rows
// (docs section 25) — enforced by DoctorDecisionService being the only
// provider injecting DoctorReviewsRepository/DoctorDiagnosesRepository.
model DoctorReview {
