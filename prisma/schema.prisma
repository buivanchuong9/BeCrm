  doctorId              String             @map("doctor_id") @db.Uuid
  action                DoctorReviewAction
  acceptedConditionCode String?            @map("accepted_condition_code")
  rationale             String?
  reviewedAt            DateTime           @default(now()) @map("reviewed_at") @db.Timestamptz

  encounter    MedicalEncounter         @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  aiAssessment AIPreliminaryAssessment? @relation(fields: [aiAssessmentId], references: [id], onDelete: SetNull)

  @@index([encounterId])
  @@map("doctor_reviews")
}

enum DiagnosisStatus {
  none
  provisional
  differential
  confirmed
  revised
  signed
}

// Append-only/versioned: reviseDiagnosis never edits a row in place, it marks
// the prior row `revised` and inserts a new one with revisionOfId set
// (docs section 25 DX-5, section 41 "Diagnosis revision").
model DoctorDiagnosis {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId      String          @map("encounter_id") @db.Uuid
  doctorId         String          @map("doctor_id") @db.Uuid
  status           DiagnosisStatus
  conditionName    String          @map("condition_name")
  conditionCode    String?         @map("condition_code")
  aiAssessmentId   String?         @map("ai_assessment_id") @db.Uuid
  isAdditionalToAI Boolean         @map("is_additional_to_ai")
  rationale        String?
  revisionOfId     String?         @unique @map("revision_of_id") @db.Uuid
  version          Int             @default(1)
  recordedAt       DateTime        @default(now()) @map("recorded_at") @db.Timestamptz

  encounter     MedicalEncounter         @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  aiAssessment  AIPreliminaryAssessment? @relation(fields: [aiAssessmentId], references: [id], onDelete: SetNull)
  revisionOf    DoctorDiagnosis?         @relation("DiagnosisRevision", fields: [revisionOfId], references: [id], onDelete: SetNull)
  revisedBy     DoctorDiagnosis?         @relation("DiagnosisRevision")
  clinicalPlans ClinicalPlan[]

  @@index([encounterId])
  @@map("doctor_diagnoses")
}

// One approved plan per encounter (docs section 25 DX-6) — approving it may
// auto-activate a workflow instance (docs section 28 ACT-1), handled at the
// service layer once the Workflow module exists.
model ClinicalPlan {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encounterId String   @unique @map("encounter_id") @db.Uuid
  doctorId    String   @map("doctor_id") @db.Uuid
  diagnosisId String   @map("diagnosis_id") @db.Uuid
  summary     String
  approvedAt  DateTime @default(now()) @map("approved_at") @db.Timestamptz

  encounter MedicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  diagnosis DoctorDiagnosis  @relation(fields: [diagnosisId], references: [id], onDelete: Restrict)

  @@map("clinical_plans")
}

enum ClinicalOrderType {
  laboratory
  imaging
  consultation
}

enum ClinicalOrderStatus {
  requested
  in_progress
  invalid_sample
  result_ready
  completed
  cancelled
