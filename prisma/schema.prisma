  patientId            String          @map("patient_id") @db.Uuid
  parentEncounterId    String?         @map("parent_encounter_id") @db.Uuid
  // FK lives here (not on Appointment) so one appointment maps to at most one
  // encounter; Appointment.encounter is Prisma's virtual reverse of this field.
  appointmentId        String?         @unique @map("appointment_id") @db.Uuid
  type                 EncounterType
  origin               EncounterOrigin
