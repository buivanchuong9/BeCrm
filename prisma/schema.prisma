model BpmProcessTemplate {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  code        String?   @db.VarChar(100)
  category    String?   @db.VarChar(100)
  status      String    @default("draft") @db.VarChar(30)
  description String?
  version     Int       @default(1)
  // BPMN 2.0 XML — stored alongside ReactFlow JSON for engine deployment
  xmlData     String?   @map("xml_data")       @db.Text
  xmlVersion  Int       @default(0) @map("xml_version")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String    @map("created_by") @db.Uuid
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy   String    @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy   String?   @map("deleted_by") @db.Uuid
  rowVersion  Int       @default(1) @map("row_version")

  nodes               BpmNode[]
  edges               BpmEdge[]
  instances           BpmProcessInstance[]
  slaConfigs          BpmSlaConfig[]
  variableDeclares    BpmVariableDeclare[]
  workflowStatuses    BpmWorkflowStatus[]
  serviceLevels       BpmServiceLevel[]
  bpmObjects          BpmObject[]
  bpmTriggers         BpmTrigger[]
  assignmentRules     BpmAssignmentRule[]
  segmentFilters      BpmSegmentFilter[]
  formPopups          BpmFormPopup[]
  processPermissions  BpmProcessPermission[]

  @@unique([tenantId, code])
  @@map("bpm_process_templates")
  @@schema("bpm")
}

model BpmNode {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  templateId  String    @map("template_id") @db.Uuid
  nodeKey     String    @map("node_key") @db.VarChar(100)
  nodeType    String    @map("node_type") @db.VarChar(50)
  name        String    @db.VarChar(255)
  positionX   Float     @default(0) @map("position_x")
  positionY   Float     @default(0) @map("position_y")
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String    @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  template    BpmProcessTemplate @relation(fields: [templateId], references: [id])
  fromEdges   BpmEdge[]          @relation("EdgeFrom")
  toEdges     BpmEdge[]          @relation("EdgeTo")
  taskTokens  BpmTaskToken[]

  @@unique([templateId, nodeKey])
  @@map("bpm_nodes")
  @@schema("bpm")
}

model BpmEdge {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  templateId String    @map("template_id") @db.Uuid
  edgeKey    String    @map("edge_key") @db.VarChar(100)
  fromNodeId String    @map("from_node_id") @db.Uuid
  toNodeId   String    @map("to_node_id") @db.Uuid
  label      String?   @db.VarChar(100)
  condition  Json?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy  String    @map("created_by") @db.Uuid

  template BpmProcessTemplate @relation(fields: [templateId], references: [id])
  fromNode BpmNode            @relation("EdgeFrom", fields: [fromNodeId], references: [id])
  toNode   BpmNode            @relation("EdgeTo", fields: [toNodeId], references: [id])

  @@map("bpm_edges")
  @@schema("bpm")
}

model BpmProcessInstance {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  templateId   String    @map("template_id") @db.Uuid
  refType      String?   @map("ref_type") @db.VarChar(50)
  refId        String?   @map("ref_id") @db.Uuid
  status       String    @default("running") @db.VarChar(30)
  businessKey  String?   @map("business_key") @db.VarChar(100) // Human-readable ticket code e.g. REQ-2026-001
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  iamStartedBy String    @map("iam_started_by") @db.Uuid
  variables    Json?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String    @map("created_by") @db.Uuid
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String    @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  template              BpmProcessTemplate      @relation(fields: [templateId], references: [id])
  tokens                BpmTaskToken[]
  workOrders            BpmWorkOrder[]
  history               BpmInstanceHistory[]
  gridData              BpmGridData[]
  processedObject       BpmProcessedObject?
  variableInstances     BpmVariableInstance[]
  formDataEntries       BpmFormData[]
  serviceLevelHistories BpmServiceLevelHistory[]

  @@index([tenantId, status])
  @@index([tenantId, businessKey])
  @@map("bpm_process_instances")
  @@schema("bpm")
}

model BpmTaskToken {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  instanceId      String    @map("instance_id") @db.Uuid
  nodeId          String    @map("node_id") @db.Uuid
  status          String    @default("active") @db.VarChar(30)
  iamAssigneeId   String?   @map("iam_assignee_id") @db.Uuid
  candidateGroups Json?     @map("candidate_groups")      // Array of group/dept/role IDs that can claim
  slaDueDate      DateTime? @map("sla_due_date") @db.Timestamptz
  claimedAt       DateTime? @map("claimed_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  variables       Json?                                    // Context variables inherited from instance
  formData        Json?     @map("form_data")              // E-Form submission data from this task
  delegatedFrom   String?   @map("delegated_from") @db.Uuid // Parent token ID if this was a delegation
  delegateReason  String?   @map("delegate_reason")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy       String    @map("created_by") @db.Uuid
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy       String    @map("updated_by") @db.Uuid

  instance BpmProcessInstance @relation(fields: [instanceId], references: [id])
  node     BpmNode            @relation(fields: [nodeId], references: [id])

  @@index([tenantId, status, iamAssigneeId])
  @@index([slaDueDate])                                    // For SLA breach cronjob queries
  @@map("bpm_task_tokens")
  @@schema("bpm")
}

model BpmWorkOrder {
