// ─────────────────────────────────────────────────────────────────────────────
// CareFollow — Prisma Schema
// Multi-schema: iam | crm | ticket | warranty | bpm | notification
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["iam", "crm", "ticket", "warranty", "bpm", "notification"]
}

// ═════════════════════════════════════════════════════════════════════════════
// IAM SCHEMA — Identity & Access Management
// ═════════════════════════════════════════════════════════════════════════════

model Tenant {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(255)
  domain      String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  plan        String?   @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  users       User[]
  departments Department[]
  roles       Role[]
  employees   Employee[]

  @@map("tenants")
  @@schema("iam")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  username     String    @db.VarChar(100)
  email        String?   @db.VarChar(255)
  phone        String?   @db.VarChar(30)
  passwordHash String    @map("password_hash")
  name         String    @db.VarChar(255)
  avatar       String?   @db.VarChar(500)
  gender       String?   @db.VarChar(10)
  isActive     Boolean   @default(true) @map("is_active")
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String?   @map("created_by") @db.Uuid
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy    String?   @map("deleted_by") @db.Uuid
  rowVersion   Int       @default(1) @map("row_version")

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  userRoles   UserRole[]
  employee    Employee?
  loginLogs   UserLoginLog[]
  fcmDevices  FcmDevice[]

  @@unique([tenantId, username])
  @@map("users")
  @@schema("iam")
}

model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  code        String    @db.VarChar(100)
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String    @map("created_by") @db.Uuid
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy   String    @map("updated_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy   String?   @map("deleted_by") @db.Uuid
  rowVersion  Int       @default(1) @map("row_version")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, code])
  @@map("roles")
  @@schema("iam")
}

model UserRole {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy String    @map("created_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
  @@schema("iam")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  resourceCode String   @map("resource_code") @db.VarChar(100)
  action       String   @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String   @map("created_by") @db.Uuid

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, resourceCode, action])
  @@map("role_permissions")
  @@schema("iam")
}

model Department {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  parentId   String?   @map("parent_id") @db.Uuid
  code       String?   @db.VarChar(50)
  name       String    @db.VarChar(255)
  position   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy  String    @map("created_by") @db.Uuid
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy  String    @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy  String?   @map("deleted_by") @db.Uuid
  rowVersion Int       @default(1) @map("row_version")

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  parent   Department? @relation("DeptParent", fields: [parentId], references: [id])
  children Department[] @relation("DeptParent")
  employees Employee[]

  @@map("departments")
  @@schema("iam")
}

model Employee {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  userId       String?   @unique @map("user_id") @db.Uuid
  departmentId String?   @map("department_id") @db.Uuid
  code         String?   @db.VarChar(50)
  name         String    @db.VarChar(255)
  phone        String?   @db.VarChar(30)
  email        String?   @db.VarChar(255)
  avatar       String?   @db.VarChar(500)
  position     String?   @db.VarChar(100)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String    @map("created_by") @db.Uuid
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String    @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy    String?   @map("deleted_by") @db.Uuid
  rowVersion   Int       @default(1) @map("row_version")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@map("employees")
  @@schema("iam")
}

model UserLoginLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  loggedAt  DateTime @default(now()) @map("logged_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("user_login_logs")
  @@schema("iam")
}

model Customer {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  code              String?   @db.VarChar(50)
  name              String    @db.VarChar(255)
  phone             String?   @db.VarChar(30)
  email             String?   @db.VarChar(255)
  gender            String?   @db.VarChar(10)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  address           String?
  avatarUrl         String?   @map("avatar_url") @db.VarChar(500)
  customerGroupId   String?   @map("customer_group_id") @db.Uuid
  customerSourceId  String?   @map("customer_source_id") @db.Uuid
  iamEmployeeId     String?   @map("iam_employee_id") @db.Uuid
  note              String?
  status            Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy         String    @map("created_by") @db.Uuid
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy         String    @map("updated_by") @db.Uuid
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy         String?   @map("deleted_by") @db.Uuid
  rowVersion        Int       @default(1) @map("row_version")

  extraInfos      CustomerExtraInfo[]
  customerGroup   CustomerGroup?   @relation(fields: [customerGroupId], references: [id])
  customerSource  CustomerSource?  @relation(fields: [customerSourceId], references: [id])

  @@map("customers")
  @@schema("iam")
}

model CustomerGroup {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(255)
  position   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy  String    @map("created_by") @db.Uuid
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy  String    @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy  String?   @map("deleted_by") @db.Uuid
  rowVersion Int       @default(1) @map("row_version")

  customers Customer[]

  @@map("customer_groups")
  @@schema("iam")
}

model CustomerSource {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(255)
  position   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy  String    @map("created_by") @db.Uuid
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy  String    @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy  String?   @map("deleted_by") @db.Uuid
  rowVersion Int       @default(1) @map("row_version")

  customers Customer[]

  @@map("customer_sources")
  @@schema("iam")
}

model CustomerAttribute {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  name         String    @db.VarChar(100)
  fieldName    String    @map("field_name") @db.VarChar(100)
  dataType     String    @map("data_type") @db.VarChar(30)
  isRequired   Boolean   @default(false) @map("is_required")
  isReadonly   Boolean   @default(false) @map("is_readonly")
  isUnique     Boolean   @default(false) @map("is_unique")
  options      Json?
  numberFormat String?   @map("number_format") @db.VarChar(30)
  position     Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String    @map("created_by") @db.Uuid
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String    @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy    String?   @map("deleted_by") @db.Uuid
  rowVersion   Int       @default(1) @map("row_version")

  parent     CustomerAttribute?  @relation("CustAttrParent", fields: [parentId], references: [id])
  children   CustomerAttribute[] @relation("CustAttrParent")
  extraInfos CustomerExtraInfo[]

  @@unique([tenantId, fieldName])
  @@map("customer_attributes")
  @@schema("iam")
}

model CustomerExtraInfo {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  attributeDefId String   @map("attribute_def_id") @db.Uuid
  value          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy      String   @map("updated_by") @db.Uuid

  customer     Customer          @relation(fields: [customerId], references: [id])
  attributeDef CustomerAttribute @relation(fields: [attributeDefId], references: [id])

  @@unique([customerId, attributeDefId])
  @@map("customer_extra_infos")
  @@schema("iam")
}

model CustomerScheduler {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  iamEmployeeId String?  @map("iam_employee_id") @db.Uuid
  title        String    @db.VarChar(500)
  content      String?
  scheduledAt  DateTime  @map("scheduled_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  status       String    @default("pending") @db.VarChar(30)
  result       String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String    @map("created_by") @db.Uuid
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String    @map("updated_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy    String?   @map("deleted_by") @db.Uuid
  rowVersion   Int       @default(1) @map("row_version")

  @@index([tenantId, customerId])
  @@map("customer_schedulers")
  @@schema("iam")
}

model CustomerExchange {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  iamAuthorId   String    @map("iam_author_id") @db.Uuid
  exchangeType  String    @default("note") @map("exchange_type") @db.VarChar(30)
  content       String?
  contentDelta  Json?     @map("content_delta")
  mediaUrls     Json?     @map("media_urls")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy     String?   @map("deleted_by") @db.Uuid

  @@index([tenantId, customerId])
  @@map("customer_exchanges")
  @@schema("iam")
}

model CustomerViewer {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  iamUserId   String    @map("iam_user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String    @map("created_by") @db.Uuid

  @@unique([customerId, iamUserId])
  @@map("customer_viewers")
  @@schema("iam")
}

model CustomerRelationship {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  customerId      String    @map("customer_id") @db.Uuid
  relatedId       String    @map("related_id") @db.Uuid
  relationshipType String   @map("relationship_type") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy       String    @map("created_by") @db.Uuid
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  @@index([tenantId, customerId])
  @@map("customer_relationships")
  @@schema("iam")
}

model TelesaleCall {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  iamEmployeeId String    @map("iam_employee_id") @db.Uuid
  callType      String    @default("outbound") @map("call_type") @db.VarChar(20)
  duration      Int?
  status        String    @default("completed") @db.VarChar(30)
  note          String?
  recordingUrl  String?   @map("recording_url") @db.VarChar(500)
  calledAt      DateTime  @default(now()) @map("called_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy     String    @map("created_by") @db.Uuid
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy     String    @map("updated_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  @@index([tenantId, customerId])
  @@map("telesale_calls")
  @@schema("iam")
}

model CustomerField {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(255)
  fieldKey   String    @map("field_key") @db.VarChar(100)
  fieldType  String    @default("text") @map("field_type") @db.VarChar(30)
  isRequired Boolean   @default(false) @map("is_required")
  isActive   Boolean   @default(true) @map("is_active")
  position   Int       @default(0)
  options    Json?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy  String    @map("created_by") @db.Uuid
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy  String    @map("updated_by") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy  String?   @map("deleted_by") @db.Uuid

  @@unique([tenantId, fieldKey])
  @@map("customer_fields")
  @@schema("iam")
}

model BoughtCard {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  customerId     String    @map("customer_id") @db.Uuid
  cardId         String?   @map("card_id") @db.Uuid
  cardNumber     String?   @map("card_number") @db.VarChar(100)
  issuedAt       DateTime? @map("issued_at") @db.Timestamptz
  expiredAt      DateTime? @map("expired_at") @db.Timestamptz
  points         Int       @default(0)
  status         String    @default("active") @db.VarChar(30)
