  "info": {
    "title": "DermaHealth Backend API",
    "description": "Clinic workflow backend: identity, scheduling, clinical, workflow, EMR, CRM.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "refresh_token"
      }
    },
    "schemas": {
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "nguyenvana@example.test"
          },
          "password": {
            "type": "string",
            "example": "a-strong-password"
          },
          "rememberMe": {
            "type": "boolean",
            "default": false
          },
          "mfaCode": {
            "type": "string",
            "description": "Reserved for MFA rollout; not yet enforced."
          }
        },
        "required": [
          "email",
          "password",
          "rememberMe"
        ]
      },
      "EndAllSessionsRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "description": "Optional re-confirmation of the current password."
          }
        }
      },
      "UpdateCurrentUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "avatarFileId": {
            "type": "string"
          },
          "version": {
            "type": "number"
          }
        },
        "required": [
          "version"
        ]
      },
      "NotificationChannelsDto": {
        "type": "object",
        "properties": {
          "inApp": {
            "type": "boolean"
          },
          "email": {
            "type": "boolean"
          },
          "sms": {
            "type": "boolean"
          },
          "push": {
            "type": "boolean"
          }
        },
        "required": [
          "inApp",
          "email",
          "sms",
          "push"
        ]
      },
      "DeviceSettingsDto": {
        "type": "object",
        "properties": {
          "biometricLogin": {
            "type": "boolean"
          },
          "mobileNotifications": {
            "type": "boolean"
          }
        },
        "required": [
          "biometricLogin",
          "mobileNotifications"
        ]
      },
      "UpsertUserPreferenceRequest": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "enum": [
              "vi-VN",
              "en-US"
            ]
          },
          "timezone": {
            "type": "string",
            "example": "Asia/Ho_Chi_Minh"
          },
          "dateFormat": {
            "type": "string",
            "enum": [
              "DD/MM/YYYY",
              "MM/DD/YYYY"
            ]
          },
          "theme": {
            "type": "string",
            "enum": [
              "light",
              "dark",
              "system"
            ]
          },
          "notificationChannels": {
            "$ref": "#/components/schemas/NotificationChannelsDto"
          },
          "deviceSettings": {
            "$ref": "#/components/schemas/DeviceSettingsDto"
          },
          "version": {
            "type": "number"
          }
        },
        "required": [
          "locale",
          "timezone",
          "dateFormat",
          "theme",
          "notificationChannels",
          "deviceSettings",
          "version"
        ]
      }
    }
  }
}