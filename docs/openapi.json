  "info": {
    "title": "DermaHealth Backend API",
    "description": "Clinic workflow backend: identity, scheduling, clinical, workflow, EMR, CRM.",
    "version": "2.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "refresh_token"
      }
    },
    "schemas": {
      "UserMembershipResponseDto": {
        "type": "object",
        "properties": {
          "organizationId": {
            "type": "string",
            "format": "uuid"
          },
          "clinicLocationId": {
            "type": "object",
            "format": "uuid",
            "nullable": true
          },
          "departmentId": {
            "type": "object",
            "format": "uuid",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": [
              "super_administrator",
              "patient",
              "doctor",
              "nurse",
              "receptionist",
              "lab_technician",
              "imaging_technician",
              "pharmacist",
              "care_coordinator",
              "customer_care_employee",
              "medical_administrator",
              "system_administrator",
              "clinical_process_designer"
            ]
          }
        },
        "required": [
          "organizationId",
          "clinicLocationId",
          "departmentId",
          "role"
        ]
      },
      "CurrentUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "nullable": true
          },
          "avatarUrl": {
            "type": "object",
            "nullable": true,
            "description": "Short-lived or transformed URL; null until T09 file service ships."
          },
          "status": {
            "type": "string",
            "enum": [
              "invited",
              "active",
              "locked",
              "disabled"
            ]
          },
          "activeOrganizationId": {
            "type": "object",
            "format": "uuid",
            "nullable": true
          },
          "memberships": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserMembershipResponseDto"
            }
          },
          "version": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "phone",
          "avatarUrl",
          "status",
          "activeOrganizationId",
          "memberships",
          "version"
        ]
      },
      "SessionResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "accessTokenExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "$ref": "#/components/schemas/CurrentUserResponseDto"
          }
        },
        "required": [
          "accessToken",
          "accessTokenExpiresAt",
          "user"
        ]
      },
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "nguyenvana@example.test"
          },
          "password": {
            "type": "string",
            "example": "a-strong-password"
          },
          "rememberMe": {
            "type": "boolean",
            "default": false
          },
          "mfaCode": {
            "type": "string",
            "description": "Reserved for MFA rollout; not yet enforced."
          }
        },
        "required": [
          "email",
          "password",
          "rememberMe"
        ]
      },
      "EndAllSessionsRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "description": "Optional re-confirmation of the current password."
          }
        }
      },
      "UpdateCurrentUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "avatarFileId": {
            "type": "string"
          },
          "version": {
            "type": "number"
          }
        },
        "required": [
          "version"
        ]
      },
      "NotificationChannelsResponseDto": {
        "type": "object",
        "properties": {
          "inApp": {
            "type": "boolean"
          },
          "email": {
            "type": "boolean"
          },
          "sms": {
            "type": "boolean"
          },
          "push": {
            "type": "boolean"
          }
        },
        "required": [
          "inApp",
          "email",
          "sms",
          "push"
        ]
      },
      "DeviceSettingsResponseDto": {
        "type": "object",
        "properties": {
          "biometricLogin": {
            "type": "boolean"
          },
          "mobileNotifications": {
            "type": "boolean"
          }
        },
        "required": [
          "biometricLogin",
          "mobileNotifications"
        ]
      },
      "UserPreferenceResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "locale": {
            "type": "string",
            "enum": [
              "vi-VN",
              "en-US"
            ]
          },
          "timezone": {
            "type": "string"
          },
          "dateFormat": {
            "type": "string",
            "enum": [
              "DD/MM/YYYY",
              "MM/DD/YYYY"
            ]
          },
          "theme": {
            "type": "string",
            "enum": [
              "light",
              "dark",
              "system"
            ]
          },
          "notificationChannels": {
            "$ref": "#/components/schemas/NotificationChannelsResponseDto"
          },
          "deviceSettings": {
            "$ref": "#/components/schemas/DeviceSettingsResponseDto"
          },
          "version": {
            "type": "number"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "userId",
          "locale",
          "timezone",
          "dateFormat",
          "theme",
          "notificationChannels",
          "deviceSettings",
          "version",
          "updatedAt"
        ]
      },
      "NotificationChannelsDto": {
        "type": "object",
        "properties": {
          "inApp": {
            "type": "boolean"
          },
          "email": {
            "type": "boolean"
          },
          "sms": {
            "type": "boolean"
          },
          "push": {
            "type": "boolean"
          }
        },
        "required": [
          "inApp",
          "email",
          "sms",
          "push"
        ]
      },
      "DeviceSettingsDto": {
        "type": "object",
        "properties": {
          "biometricLogin": {
            "type": "boolean"
          },
          "mobileNotifications": {
            "type": "boolean"
          }
        },
        "required": [
          "biometricLogin",
          "mobileNotifications"
        ]
      },
      "UpsertUserPreferenceRequest": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "enum": [
              "vi-VN",
              "en-US"
            ]
          },
          "timezone": {
            "type": "string",
            "example": "Asia/Ho_Chi_Minh"
          },
          "dateFormat": {
            "type": "string",
            "enum": [
              "DD/MM/YYYY",
              "MM/DD/YYYY"
            ]
          },
          "theme": {
            "type": "string",
