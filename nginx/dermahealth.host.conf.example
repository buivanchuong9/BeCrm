# Nginx running directly on the Ubuntu host (nginx/1.18.0) — TLS termination
# happens here; it proxies to the DermaHealth API container via its
# host-published port. Use this variant when nginx is NOT itself a container
# on the app's Docker network (contrast with dermahealth.compose.conf.example).
#
# Install on the Ubuntu server:
#   sudo cp nginx/dermahealth.host.conf.example /etc/nginx/sites-available/dermahealth.conf
#   sudo ln -sf /etc/nginx/sites-available/dermahealth.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Matches docker-compose.prod.yml, which publishes the `api` service as
# 127.0.0.1:43000 -> container port 3000 (NestJS `PORT` env var, see
# .env.example). If you change that port mapping, update the upstream below
# to match.
#
# DermaHealth API surface (see src/bootstrap.ts / src/main.ts): global prefix
# /api (business routes under /api/v1/...), release-versioned Swagger UI at
# /api/docs/<release> with /api/docs kept for compatibility, health checks
# unprefixed at /health/live and /health/ready. There is no /authenticator,
# /adminapi, /bpmapi, /notification, or /sale route — this backend is a single
# NestJS modular monolith, not the legacy multi-service CareFollow backend.

upstream dermahealth_be_host {
    server 127.0.0.1:43000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name dermahealth.fitdnu.id.vn;

    # Certbot / Let's Encrypt — uncomment once a certificate has been issued
    # for this server_name (e.g. via `sudo certbot --nginx`).
    # return 301 https://$host$request_uri;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Until SSL is configured, serve API traffic here too so /api/docs is
    # reachable immediately after deploy.
    location ~ ^/(api|health)(/|$) {
        proxy_pass http://dermahealth_be_host;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dermahealth.fitdnu.id.vn;

    # ssl_certificate     /etc/letsencrypt/live/dermahealth.fitdnu.id.vn/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/dermahealth.fitdnu.id.vn/privkey.pem;

    client_max_body_size 25m;

    # Everything this backend serves lives under /api/... (REST + versioned
    # Swagger UI) or the unprefixed /health/{live,ready} checks. The app emits
    # no-store headers for every /api/docs response; nginx passes them through.
    location ~ ^/(api|health)(/|$) {
        proxy_pass http://dermahealth_be_host;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    # Convenience redirect so /docs also reaches Swagger UI.
    location = /docs {
        return 301 /api/docs;
    }

    # This repository is backend-only — the DermaHealth frontend (../User)
    # is a separate deploy target (T19+ frontend integration, not started).
    # Until a frontend is served from this host, anything outside /api and
    # /health legitimately 404s rather than falling through to a SPA index.
    location / {
        return 404;
    }
}
