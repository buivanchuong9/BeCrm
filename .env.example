# === App ===
NODE_ENV=development
PORT=3000
API_BASE_PATH=/api/v1
# Optional release override. When omitted, package.json version is used so a
# normal git pull + API rebuild publishes the next versioned documentation URL.
# OPENAPI_VERSION=2.5.0

# === CORS / public URL ===
FRONTEND_ORIGINS=http://localhost:5173
APP_PUBLIC_URL=http://localhost:3000
REQUEST_BODY_LIMIT=1mb
TRUST_PROXY_HOPS=0
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# === Database (Prisma / PostgreSQL 16) ===
DATABASE_URL=postgresql://app:dev@127.0.0.1:5442/dermahealth?schema=public

# === Redis (BullMQ, throttling, short-lived idempotency support) ===
REDIS_URL=redis://127.0.0.1:6389

# === Auth: access/refresh tokens ===
# Generate a dev keypair, e.g.: openssl genpkey -algorithm RSA -out access_private.pem -pkeyopt rsa_keygen_bits:2048
# Paste PEM contents with literal \n newlines, or point CI/secret-manager at file-based secrets in real environments.
ACCESS_TOKEN_PRIVATE_KEY=REPLACE_WITH_PEM_PRIVATE_KEY
ACCESS_TOKEN_PUBLIC_KEY=REPLACE_WITH_PEM_PUBLIC_KEY
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=30d
REFRESH_TOKEN_TTL_NOT_REMEMBERED=24h
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# === Password / field-level protection ===
PASSWORD_PEPPER=REPLACE_WITH_RANDOM_DEV_VALUE
FIELD_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# === S3-compatible storage (MinIO locally) ===
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dermahealth-private-dev
S3_ACCESS_KEY=REPLACE_WITH_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_MINIO_SECRET_KEY
S3_FORCE_PATH_STYLE=true

# === Mail (Mailpit locally) ===
MAIL_FROM=no-reply@dermahealth.example.test
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# === SMS (disabled by default; safe default per spec section 47) ===
SMS_PROVIDER=disabled
SMS_API_KEY=

# === AI adapter ===
AI_PROVIDER=deterministic
AI_MODEL_VERSION=derma-vision-2.4.0
AI_API_KEY=

# === Observability ===
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Seed (development only; refused when NODE_ENV=production) ===
SEED_DEMO_PASSWORD=REPLACE_WITH_LOCAL_DEV_PASSWORD
